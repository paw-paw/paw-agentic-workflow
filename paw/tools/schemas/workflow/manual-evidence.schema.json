{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paw.local/schemas/workflow/manual-evidence.schema.json",
  "title": "PAW manual conformance evidence",
  "type": "object",
  "required": ["reviewer", "date", "reviewed_object", "criterion", "result", "references"],
  "properties": {
    "reviewer": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "reviewed_object": { "type": "string", "minLength": 1 },
    "criterion": { "type": "string", "minLength": 1 },
    "result": {
      "enum": ["pass", "fail", "deferred", "accepted-gap", "blocked"]
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
