{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paw.local/schemas/workflow/conformance.schema.json",
  "title": "PAW conformance rule contract",
  "type": "object",
  "required": ["schema_version", "document", "role", "rule", "check", "enforcement"],
  "properties": {
    "schema_version": { "const": 1 },
    "document": { "type": "string", "minLength": 1 },
    "role": {
      "enum": ["strategic", "contract", "verifiable", "operational"]
    },
    "rule": { "type": "string", "minLength": 1 },
    "check": {
      "type": "object",
      "required": ["disposition"],
      "properties": {
        "disposition": {
          "enum": [
            "existing-check",
            "new-automated-check",
            "manual-with-evidence",
            "generated",
            "deferred",
            "accepted-gap",
            "blocked"
          ]
        }
      },
      "additionalProperties": true
    },
    "enforcement": {
      "enum": ["manual", "automated", "ci-gated"]
    }
  },
  "additionalProperties": true
}
