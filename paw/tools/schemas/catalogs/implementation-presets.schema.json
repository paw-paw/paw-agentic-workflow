{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paw.local/schemas/catalogs/implementation-presets.schema.json",
  "type": "object",
  "required": ["schema_version", "catalog_id", "catalog_version", "review_policy", "completeness_dimensions", "sources", "presets"],
  "properties": {
    "schema_version": {"const": 1},
    "catalog_id": {"const": "implementation-presets"},
    "catalog_version": {"type": "string"},
    "review_policy": {"type": "object"},
    "completeness_dimensions": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string"}},
    "sources": {"type": "array", "minItems": 1},
    "presets": {"type": "array", "minItems": 11}
  },
  "additionalProperties": false
}
